# Dependencies and build output (rebuilt inside the image).
node_modules
dist
build
.next
.turbo
*.tsbuildinfo

# Local env / secrets — never bake into the image.
.env
.env.local
.env.*
!.env.example

# Logs.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git and VCS.
.git
.gitignore
.gitattributes

# Editor / IDE / local tooling.
.vscode
.idea
.cursor
*.swp
*.swo

# Test and coverage artifacts.
coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
playwright-report
test-results
.tmp

# Local databases.
*.db
*.db-journal
prisma/dev.db
prisma/shadow.db
shadow.db

# Docs and design assets not needed at runtime.
docs
*.md
!README.md
