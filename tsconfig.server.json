{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "types": ["node", "vite/client"],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts", "scripts/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
