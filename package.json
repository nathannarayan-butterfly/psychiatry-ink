{
  "name": "psychiatry-ink",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npm run dev",
    "build": "tsc -b && vite build",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck": "npm run typecheck:app && npm run typecheck:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:fixture:write": "tsx scripts/write-demo-patient-fixture.ts",
    "demo:fixture:regen": "tsx scripts/regen-demo-patient-fixture.ts",
    "preview": "vite preview",
    "audit:workflows": "npx --yes tsx scripts/audit-workflows.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:check": "tsx scripts/db-check.ts",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "db:build-diagnoses": "tsx scripts/build-diagnosis-crosswalk.ts",
    "db:seed-diagnoses": "tsx scripts/seed-diagnosis-codes.ts",
    "db:import-diagnoses": "npm run db:build-diagnoses && npm run db:seed-diagnoses",
    "kb:seed:psychiatric-drugs": "tsx scripts/seed-psychiatric-drug-kb.ts",
    "kb:verify": "tsx scripts/verify-kb-substance.ts",
    "kb:publish-all": "tsx scripts/publish-all-kb-substances.ts",
    "kb:translate-de": "tsx scripts/translate-kb-to-german.ts",
    "postinstall": "prisma generate",
    "dev:stop": "bash scripts/stop-dev.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "livekit-client": "^2.19.2",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^0.511.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0"
  }
}
