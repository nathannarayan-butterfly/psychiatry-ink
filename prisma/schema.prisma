// Psychiatry.ink — local SQLite via Prisma
// Server-side only (see server/db.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Metadata-only AI generation usage log (no clinical text).
model GenerationLog {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
  documentType         String
  aiMode               String
  inputTextLength      Int
  estimatedInputTokens Int
  estimatedCredits     Int
  provider             String?
  model                String?
  status               String
  errorMessage         String?
  tool                 String?
  scope                String?
  schemaId             String?
  resultTextLength     Int?
  creditsDeducted      Boolean   @default(false)
}

/// Per-user credit balance (Supabase user id or "default" for local dev).
model CreditBalance {
  id        String   @id
  balance   Int      @default(200)
  plan      String   @default("free")
  updatedAt DateTime @updatedAt
}

/// App-level preferences persisted locally (optional migration from localStorage later).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Browser-generated public key only — never stores patient name/age.
model UserPublicKey {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  publicKeyJwk String
  countryCode  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Zero-knowledge encrypted workspace snapshot (ciphertext only — server never decrypts).
/// One row per patient case; name/age never included in ciphertext.
model EncryptedWorkspaceSnapshot {
  id         String   @id @default(cuid())
  userId     String
  caseId     String
  deviceId   String
  ciphertext String
  iv         String
  wrappedKey String
  version    Int      @default(1)
  titleHint  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([userId, caseId])
}

/// Patient case metadata — stored locally in SQLite, shared across browsers for the same account.
model PatientCase {
  caseId            String   @id
  accountId         String
  localName         String?
  localVorname      String?
  localNachname     String?
  localGeburtsdatum String?
  localGeschlecht   String?
  localAge          String?
  pageHeading       String?
  lastDocumentType  String?
  lastOpened        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  diagnoses PatientDiagnosis[]

  @@index([accountId, lastOpened])
}

/// Diagnosis entries per patient case (ICD-10 / ICD-11 / DSM crosswalk).
model PatientDiagnosis {
  id              String   @id @default(cuid())
  caseId          String
  accountId       String
  icd10Code       String   @default("")
  icd10Label      String   @default("")
  icd10Overridden Boolean  @default(false)
  icd11Code       String   @default("")
  icd11Label      String   @default("")
  icd11Overridden Boolean  @default(false)
  dsmCode         String   @default("")
  dsmLabel        String   @default("")
  dsmOverridden   Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient PatientCase @relation(fields: [caseId], references: [caseId], onDelete: Cascade)

  @@index([accountId, caseId])
}

/// Reference diagnosis codes (ICD-10, ICD-11, DSM-5-TR) for autocomplete — not patient data.
model DiagnosisCode {
  system      String
  code        String
  labelDe     String
  icd10Code   String
  icd10Label  String
  icd11Code   String   @default("")
  icd11Label  String   @default("")
  dsmCode     String   @default("")
  dsmLabel    String   @default("")
  searchText  String

  @@id([system, code])
  @@index([system, searchText])
  @@index([icd10Code])
}
