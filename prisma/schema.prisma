// Psychiatry.ink — local SQLite via Prisma
// Server-side only (see server/db.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Metadata-only AI generation usage log (no clinical text).
/// `userId`/`organisationId` bind a log to its creator so credits are reserved
/// and deducted against the correct owner and PATCH cannot mutate another
/// account's log. Nullable for backwards compatibility with pre-migration rows.
model GenerationLog {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
  userId               String?
  organisationId       String?
  documentType         String
  aiMode               String
  inputTextLength      Int
  estimatedInputTokens Int
  estimatedCredits     Int
  provider             String?
  model                String?
  status               String
  errorMessage         String?
  tool                 String?
  scope                String?
  schemaId             String?
  resultTextLength     Int?
  creditsDeducted      Boolean   @default(false)

  @@index([userId, createdAt])
}

/// Per-user credit balance (Supabase user id or "default" for local dev).
model CreditBalance {
  id        String   @id
  balance   Int      @default(200)
  plan      String   @default("free")
  updatedAt DateTime @updatedAt
}

/// App-level preferences persisted locally (optional migration from localStorage later).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Browser-generated public key only — never stores patient name/age.
model UserPublicKey {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  publicKeyJwk String
  countryCode  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Zero-knowledge encrypted workspace snapshot (ciphertext only — server never decrypts).
/// One row per patient case; name/age never included in ciphertext.
model EncryptedWorkspaceSnapshot {
  id         String   @id @default(cuid())
  userId     String
  caseId     String
  deviceId   String
  ciphertext String
  iv         String
  wrappedKey String
  version    Int      @default(1)
  titleHint  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([userId, caseId])
}

/// Passphrase-wrapped private key backup — ciphertext only, keyed by Supabase user id.
model AccountKeyBackup {
  userId     String   @id
  salt       String
  iv         String
  ciphertext String
  iterations Int      @default(310000)
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt
}

/// Encrypted local registry bundle (names/DOB/diagnoses/vault blobs) — separate from clinical snapshots.
/// Server never joins this table with EncryptedWorkspaceSnapshot; mapping happens client-side via caseId.
model AccountRegistryBackup {
  userId     String   @id
  salt       String
  iv         String
  ciphertext String
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt
}

/// Opaque case registry — server stores ONLY the case code and non-identifying sync metadata.
/// Patient names, DOB, age, gender, and page headings live in browser localStorage / crypto vault.
model PatientCase {
  caseId           String   @id
  accountId        String
  lastDocumentType String?
  lastOpened       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([accountId, lastOpened])
}

/// Reference diagnosis codes (ICD-10, ICD-11, DSM-5-TR) for autocomplete — not patient data.
/// @deprecated Prefer DiagnosisCatalogue / DiagnosisEntry — kept for legacy crosswalk search.
model DiagnosisCode {
  system      String
  code        String
  labelDe     String
  icd10Code   String
  icd10Label  String
  icd11Code   String   @default("")
  icd11Label  String   @default("")
  dsmCode     String   @default("")
  dsmLabel    String   @default("")
  searchText  String

  @@id([system, code])
  @@index([system, searchText])
  @@index([icd10Code])
}

/// Diagnosis catalogue metadata (ICD-10-GM, ICD-11 MMS, …) — independent of criterion trees.
model DiagnosisCatalogue {
  id           String   @id @default(cuid())
  system       String
  version      String
  language     String   @default("de")
  source       String
  active       Boolean  @default(true)
  importedAt   DateTime @default(now())
  metadataJson String   @default("{}")

  entries DiagnosisEntry[]

  @@unique([system, version, language])
  @@index([active, system])
}

/// Searchable diagnosis code within a catalogue.
model DiagnosisEntry {
  id                 String   @id @default(cuid())
  catalogueId        String
  code               String
  codeNormalized     String
  title              String
  shortTitle         String?
  description        String?
  chapterCode        String?
  chapterTitle       String?
  blockCode          String?
  blockTitle         String?
  parentCode         String?
  hierarchyLevel     Int      @default(0)
  isCategory         Boolean  @default(false)
  isSelectable       Boolean  @default(true)
  isResidualCategory Boolean  @default(false)
  isPsychiatric      Boolean  @default(false)
  isSomatic          Boolean  @default(false)
  searchText         String
  sourceUri          String?
  sourceVersion      String?
  metadataJson       String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  catalogue     DiagnosisCatalogue      @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
  synonyms      DiagnosisSynonym[]
  criteriaLinks DiagnosisCriteriaLink[]

  @@unique([catalogueId, codeNormalized])
  @@index([catalogueId])
  @@index([catalogueId, searchText])
  @@index([catalogueId, codeNormalized])
  @@index([catalogueId, isPsychiatric, isSelectable])
}

model DiagnosisSynonym {
  id               String   @id @default(cuid())
  diagnosisEntryId String
  term             String
  normalizedTerm   String
  language         String   @default("de")
  source           String   @default("import")
  createdAt        DateTime @default(now())

  entry DiagnosisEntry @relation(fields: [diagnosisEntryId], references: [id], onDelete: Cascade)

  @@index([diagnosisEntryId])
  @@index([normalizedTerm])
}

/// Optional link from catalogue entry to authored criterion tree (badge only).

// ---------------------------------------------------------------------------
// AI Credit System (added: central server-side credit accounting)
// ---------------------------------------------------------------------------

/// Per-user or per-organisation credit account.
/// monthlyCredits reset each billing period; purchasedCredits never expire.
model AiCreditAccount {
  id               String   @id @default(cuid())
  userId           String?  @unique
  organisationId   String?  @unique
  monthlyCredits   Int      @default(500)
  purchasedCredits Int      @default(0)
  monthlyResetAt   DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  ledger           AiCreditLedger[]
}

/// Append-only ledger for all credit movements.
/// Positive credits = grant/purchase/refund. Negative = debit.
/// `bucket` records which bucket the entry hit ('monthly' | 'purchased').
/// A single user-visible debit that spans both buckets emits TWO ledger rows
/// (one per bucket) so analytics can split monthly vs purchased consumption.
model AiCreditLedger {
  id         String          @id @default(cuid())
  accountId  String
  account    AiCreditAccount @relation(fields: [accountId], references: [id])
  type       String          // 'monthly_grant' | 'purchase' | 'debit' | 'refund' | 'admin_adjustment'
  credits    Int             // positive = credit, negative = debit
  bucket     String          @default("monthly") // 'monthly' | 'purchased'
  featureKey String?
  usageLogId String?
  note       String?
  createdAt  DateTime        @default(now())

  @@index([accountId, createdAt])
  @@index([accountId, bucket, createdAt])
}

/// Metadata-only AI call log (no patient text, no raw prompts — only usage metadata).
///
/// `estimatedCostUsd` records the real provider USD cost (input+output tokens
/// priced per `providerCosts.ts`). Used for margin analytics — never billed
/// directly. `fallback=true` when the call landed on a non-primary provider
/// for its mode (e.g. gruendlich fell back from OpenAI to DeepSeek).
model AiUsageLog {
  id               String   @id @default(cuid())
  organisationId   String?
  userId           String?
  caseRef          String?  // de-identified case reference only
  featureKey       String
  mode             String   // economic | standard | gruendlich
  provider         String
  model            String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  creditsCharged   Int      @default(0)
  estimatedCostUsd Decimal? // real provider USD cost; up to 6 decimal places
  fallback         Boolean  @default(false)
  durationMs       Int?
  success          Boolean  @default(true)
  errorCode        String?
  rawProviderUsage String?  // JSON string; no PHI
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([featureKey, createdAt])
  @@index([provider, model, createdAt])
  @@index([success, createdAt])
  @@index([fallback, createdAt])
}

/// SKU catalogue for non-expiring extra-credit bundles (purchased on top of
/// the monthly grant). Prices are stored in GBP — the user-facing checkout
/// currency for Beta. Inactive rows remain readable for historical purchase
/// references but are not offered for purchase.
model AiCreditBundle {
  id          String   @id @default(cuid())
  sku         String   @unique // 'credits-100' | 'credits-250' | 'credits-500' | 'credits-1000' | 'credits-2500'
  credits     Int      // 100 | 250 | 500 | 1000 | 2500
  priceGbp    Decimal  // GBP price; 2 decimal places enforced in app layer
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchases   AiCreditPurchase[]
}

/// Record of a clinician's purchase intent for a credit bundle.
/// Beta deploys this as a stub: `status='pending'` is written when the user
/// clicks Purchase; Stripe checkout completion (out of scope) later moves the
/// row to `status='paid'` and emits a corresponding `AiCreditLedger` row +
/// `AiCreditAccount.purchasedCredits` increment.
model AiCreditPurchase {
  id          String    @id @default(cuid())
  userId      String
  bundleId    String
  credits     Int       // snapshot of bundle.credits at purchase time
  priceGbp    Decimal   // GBP price snapshot at purchase time
  status      String    // 'pending' | 'paid' | 'failed' | 'refunded'
  externalRef String?   // Stripe checkout session id (future)
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  bundle      AiCreditBundle @relation(fields: [bundleId], references: [id])

  @@index([userId, status])
  @@index([createdAt])
  @@index([status, createdAt])
}

/// Idempotency log for processed Stripe webhook events.
///
/// Stripe may deliver the same event multiple times (e.g. at-least-once with
/// retries when the receiver returns a non-2xx). The webhook handler records
/// every event.id it has finished processing so a replay is a no-op and the
/// credit ledger never double-counts.
model ProcessedWebhookEvent {
  eventId    String   @id
  source     String   @default("stripe")
  eventType  String
  receivedAt DateTime @default(now())

  @@index([source, receivedAt])
}

model DiagnosisCriteriaLink {
  id               String   @id @default(cuid())
  diagnosisEntryId String
  criteriaTreeId   String
  criteriaSystem   String
  supportStatus    String   @default("native")
  createdAt        DateTime @default(now())

  entry DiagnosisEntry @relation(fields: [diagnosisEntryId], references: [id], onDelete: Cascade)

  @@unique([diagnosisEntryId, criteriaTreeId, criteriaSystem])
  @@index([diagnosisEntryId])
  @@index([criteriaTreeId])
}
