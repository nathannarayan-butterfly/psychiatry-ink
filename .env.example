# Local SQLite database (Prisma) — path relative to prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# ── Supabase Auth (browser — Vite, VITE_ prefix) ─────────────────────────────
# Vite lädt .env.local MIT VORRANG vor .env — Platzhalter nur hier in .env.example.
# Echte Werte in .env.local (empfohlen) oder .env eintragen; .env.example wird nie gelesen.
#
# Dashboard: Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   Key (eine Variable, zwei Formate):
#     • Legacy anon JWT:  eyJ…              → VITE_SUPABASE_ANON_KEY
#     • Publishable key:  sb_publishable_…  → ebenfalls VITE_SUPABASE_ANON_KEY
#   NICHT im Browser: sb_secret_… oder service_role JWT
#
# Nach Änderungen: npm run dev neu starten.
# Auth → URL Configuration: Site URL http://localhost:5173, Redirect URLs http://localhost:5173/**
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ── Supabase Auth (server — optional, getrennt vom Client) ───────────────────
# Fallback auf VITE_* wenn leer. Gleiche .env.local-Vorrang-Regel wie oben.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# API server
API_PORT=3001

# Optional explicit API base for the browser (dev uses Vite proxy to API_PORT when unset)
# VITE_API_BASE_URL=http://127.0.0.1:3001

# Local dev without Supabase login — development ONLY (NODE_ENV=development)
# ENABLE_DEV_AUTH_BYPASS=true

# LLM providers (server-only — never use VITE_ prefix)
# Required for real (non-mock) Labor KI / document generation. At least one key must be set.
# schnell + standard → DeepSeek; gründlich + dictation → OpenAI (auto-fallback if only one key is set)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# KB seed + admin API (server-only — service role bypasses RLS for AI drafts)
SUPABASE_SERVICE_ROLE_KEY=

# KB admin API surface — DEFAULT FALSE for Beta safety. Only enable on
# instances that have a designated KB admin operator on call.
# KB_ADMIN_API_ENABLED=true

# KB admin UI in browser — DEFAULT FALSE for Beta safety. Mirror of the
# server flag; enable only when the admin console is intentionally exposed.
# VITE_KB_ADMIN_ENABLED=true

# WHO ICD-API (server-only — official diagnosis titles for UI display)
# Register at https://icd.who.int/icdapi → View API access key
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
# Optional release pins (defaults: ICD-11 2026-01, ICD-10 2016)
# WHO_ICD11_RELEASE=2026-01
# WHO_ICD10_RELEASE=2016

# ── Übersicht psychopathology AI (PPB Strukturieren) ─────────────────────────
# Separate from document-import AI (ENABLE_DOCUMENT_IMPORT_AI). OFF by default.
# Client + server must both be true; restart `npm run dev` after changing .env.local.
# VITE_ENABLE_PSYCHOPATH_EXTRACT_AI=true
# ENABLE_PSYCHOPATH_EXTRACT_AI=true

# Optional model overrides (server-side)
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_STANDARD_MODEL=gpt-4o-mini
OPENAI_THOROUGH_MODEL=gpt-4.1
DEEPSEEK_FAST_MODEL=deepseek-chat
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Google Gemini (OpenAI-compatible API — server-only)
GOOGLE_API_KEY=
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Clinical Intelligence V1 (Dimensional + Mechanism inference) ─────────────
# OFF by default. Module is hidden until BOTH client + server flags are true.
# Only de-identified compact evidence is ever sent — raw documents are rejected.
# Restart `npm run dev` after changing .env.local.
# VITE_CLINICAL_INTELLIGENCE_V1_ENABLED=true
# CLINICAL_INTELLIGENCE_V1_ENABLED=true
# Optional development diagnostics panel (raw JSON, tokens, validation, errors)
# VITE_CLINICAL_INTELLIGENCE_DEBUG_MODE=true
# CLINICAL_INTELLIGENCE_DEBUG_MODE=true
