# ── Database (PostgreSQL / Supabase, via Prisma) ─────────────────────────────
# IMPORTANT — migrated from SQLite (2026): `prisma/schema.prisma` is PostgreSQL
# only. If you still have `DATABASE_URL="file:./dev.db"` in `.env.local`, the
# API will start but every Prisma call fails. Vite and the API load `.env.local`
# with priority over this file — update `.env.local`, not just `.env.example`.
#
# PRODUCTION (Supabase): use the POOLED connection for the running API and the
# DIRECT connection for migrations. Find both under Supabase → Project Settings
# → Database → Connection string.
#
#   DATABASE_URL → Transaction pooler (PgBouncer, port 6543). MUST include
#                  ?pgbouncer=true so Prisma disables prepared statements.
#   DIRECT_URL   → Direct connection (port 5432). Used by `prisma migrate deploy`
#                  / `prisma db push` only (migrations can't run over PgBouncer).
#
# Example (replace <project-ref>, <password>, <region>):
#   DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#
# LOCAL DEV — pick one:
#   A) Supabase project (recommended if you already have VITE_SUPABASE_* set):
#      copy pooled + direct strings from Supabase → Database → Connection string.
#   B) Local Postgres (both vars point at the same instance for dev):
#      docker run --name psychiatry-pg -e POSTGRES_PASSWORD=postgres \
#        -e POSTGRES_DB=psychiatry_ink -p 5432:5432 -d postgres:16
#      then use the localhost URLs below.
# After changing URLs: `npx prisma migrate deploy` then restart `npm run dev`.
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"

# ── Supabase Auth (browser — Vite, VITE_ prefix) ─────────────────────────────
# EU DATA RESIDENCY: the live project is hosted in AWS eu-west-1 (Ireland, EU);
# DB/Auth/Storage share that region and it CANNOT be changed in place. See
# docs/cloud-deployment.md §6a before creating/moving a project.
# Vite lädt .env.local MIT VORRANG vor .env — Platzhalter nur hier in .env.example.
# Echte Werte in .env.local (empfohlen) oder .env eintragen; .env.example wird nie gelesen.
#
# Dashboard: Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   Key (eine Variable, zwei Formate):
#     • Legacy anon JWT:  eyJ…              → VITE_SUPABASE_ANON_KEY
#     • Publishable key:  sb_publishable_…  → ebenfalls VITE_SUPABASE_ANON_KEY
#   NICHT im Browser: sb_secret_… oder service_role JWT
#
# Nach Änderungen: npm run dev neu starten.
# Supabase → Auth → URL Configuration (PRIMARY control for confirmation links):
#   DEV  Site URL http://localhost:5173       Redirect URLs http://localhost:5173/**
#   PROD Site URL https://app.psychiatry.ink  Redirect URLs https://app.psychiatry.ink/**
#        (add every real domain you serve the app from, incl. www if used)
# The Site URL is what Supabase puts in {{ .ConfirmationURL }} unless an
# allow-listed `emailRedirectTo` is supplied. If it is left at the stale default
# (http://localhost:3000) every confirmation link 404s for real users.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Canonical public app origin used as `emailRedirectTo` for signup confirmation
# + resend emails (src/utils/authEmailRedirect.ts). Pins the link to the real
# app even if the user signed up on a marketing domain. Optional: when unset the
# code falls back to window.location.origin (correct in prod on app.psychiatry.ink
# and in dev on localhost). The target MUST also be in the Redirect-URL allow-list
# above. VITE_SITE_URL is an accepted alias.
# VITE_PUBLIC_APP_URL=https://app.psychiatry.ink

# ── Supabase Auth (server — optional, getrennt vom Client) ───────────────────
# Fallback auf VITE_* wenn leer. Gleiche .env.local-Vorrang-Regel wie oben.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# API server
API_PORT=3001
# Bind address. 0.0.0.0 inside containers; 127.0.0.1 for local-only.
# API_HOST=0.0.0.0
# Number of reverse-proxy hops to trust for client IP / rate limiting (default 1).
# TRUST_PROXY=1

# ── Deployment topology ──────────────────────────────────────────────────────
# Default = SINGLE SERVICE: the API serves the built dist/ with SPA fallback, so
# the browser talks to same-origin /api/* and VITE_API_BASE_URL can stay unset.
#
# SPLIT DEPLOY: host the frontend separately and set VITE_API_BASE_URL (at BUILD
# time for the client) to the API origin. Then you MUST also set
# CORS_ALLOWED_ORIGINS below to the frontend origin(s).
# Dev leaves this unset and uses the Vite proxy to API_PORT.
# VITE_API_BASE_URL=https://api.psychiatry.ink

# ── CORS allowlist ───────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to call the API cross-origin.
# localhost is always allowed in non-production. Required for split deploys;
# safe to leave empty for the same-origin single-service topology.
# CORS_ALLOWED_ORIGINS=https://app.psychiatry.ink,https://psychiatry.ink,https://psychiatrie.ink,https://fr.psychiatrie.ink,https://psiquiatria.ink
# Extra origins to add to the CSP connect-src (rarely needed).
# CSP_CONNECT_SRC_EXTRA=

# ── Multi-domain marketing (single deploy) ───────────────────────────────────
# All domains share one codebase, API, database, and Stripe billing.
# Hostname selects default marketing locale; user language settings override after login.
# VITE_CANONICAL_APP_DOMAIN=app.psychiatry.ink
# CANONICAL_APP_DOMAIN=app.psychiatry.ink
# VITE_DEV_MARKETING_DOMAIN=psychiatrie.ink
# Local domain testing: /etc/hosts → 127.0.0.1 psychiatry.ink psychiatrie.ink psiquiatria.ink
# Then open http://psychiatry.ink:5173 (Vite allowedHosts lists marketing domains).

# ── Rate limiting (per-instance, in-memory) ──────────────────────────────────
# NOTE: counters are per-instance. Add a shared store (rate-limit-redis) before
# scaling beyond one API instance.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_SENSITIVE_MAX=30

# ── Public contact form (Google Workspace SMTP relay via nodemailer) ─────────
# Required for /api/contact on production. Outbound mail goes through the Google
# Workspace SMTP relay using STARTTLS. SERVER-ONLY: never use a VITE_ prefix and
# never expose SMTP_USER/SMTP_PASS to the browser bundle.
#
# TWO MODES — pick one:
#
#   1) RELAY / NO-AUTH (recommended for Workspace). The relay allowlists our
#      static egress IP, so NO credentials are needed. Set SMTP_RELAY=true (or
#      SMTP_AUTH=none) and leave SMTP_USER/SMTP_PASS unset. Avoids Gmail's
#      account-level app-password rejections (535) entirely.
#        SMTP_HOST=smtp-relay.gmail.com
#        SMTP_PORT=587
#        SMTP_RELAY=true            # or SMTP_AUTH=none
#      Then allowlist the server's static egress IP in Google Admin (see below).
#
#   2) AUTHENTICATED (app password). Provide SMTP_USER + SMTP_PASS; the transport
#      authenticates to the relay with those credentials.
#
# If SMTP_HOST is missing — or, in authenticated mode, SMTP_USER/SMTP_PASS are
# missing — the route returns 503 and logs a warning. In relay mode a host alone
# is sufficient.
#
#   SMTP relay setup (Google Admin console): Apps → Google Workspace → Gmail →
#   Routing → SMTP relay service. Allow the static egress IP, set Allowed
#   senders, and require TLS.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
# Relay (no-auth) mode: relay authorises us by static egress IP, no creds needed.
# SMTP_RELAY=true
# Alternative explicit way to disable auth (equivalent to SMTP_RELAY=true):
# SMTP_AUTH=none
# Authenticated mode only — Workspace mailbox + app password. Leave unset in
# relay mode (ignored even if present). Inject SMTP_PASS from a secret in prod.
# SMTP_USER=hello@psychiatry.ink
# SMTP_PASS=
# Envelope/From shown to recipients. Use a dedicated, owned sender address.
CONTACT_FROM=Psychiatrie.Ink <noreply@psychiatry.ink>
# Routing: normal categories → CONTACT_TO; privacy (Datenschutz) → PRIVACY_TO.
CONTACT_TO=hello@psychiatry.ink
PRIVACY_TO=data-protection@psychiatry.ink
# CONTACT_RATE_LIMIT_WINDOW_MS=900000
# CONTACT_RATE_LIMIT_MAX=5
# Optional salt for IP hashing in abuse-prevention metadata (server-only).
# CONTACT_IP_HASH_SALT=
#
# PRODUCTION secrets (Google Cloud Secret Manager → Cloud Run). Create the
# secrets once, then bind them to the Cloud Run service as env vars:
#   printf '%s' 'noreply@psychiatry.ink' | gcloud secrets create SMTP_USER \
#     --data-file=- --replication-policy=automatic
#   printf '%s' '<app-password>' | gcloud secrets create SMTP_PASS --data-file=-
#   gcloud run services update psychiatry-ink-beta --region <region> \
#     --update-secrets=SMTP_USER=SMTP_USER:latest,SMTP_PASS=SMTP_PASS:latest \
#     --update-env-vars=SMTP_HOST=smtp-relay.gmail.com,SMTP_PORT=587,\
# CONTACT_FROM='Psychiatrie.Ink <noreply@psychiatry.ink>',\
# CONTACT_TO=hello@psychiatry.ink,PRIVACY_TO=data-protection@psychiatry.ink
#   # grant the runtime service account access:
#   gcloud secrets add-iam-policy-binding SMTP_PASS \
#     --member=serviceAccount:<runtime-sa> --role=roles/secretmanager.secretAccessor

# ── Outbound call timeouts (ms) ──────────────────────────────────────────────
# OUTBOUND_HTTP_TIMEOUT_MS=45000
# LLM_TIMEOUT_MS=60000
# TRANSCRIBE_TIMEOUT_MS=60000
# WHO_ICD_TIMEOUT_MS=30000
# SUPABASE_ADMIN_TIMEOUT_MS=30000
# AUTH_VALIDATION_TIMEOUT_MS=10000
# STRIPE_TIMEOUT_MS=30000
# STRIPE_MAX_NETWORK_RETRIES=1

# ── Bearer-token validation cache (token validation latency optimization) ────
# AUTH_CACHE_TTL_MS=60000
# AUTH_NEG_CACHE_TTL_MS=10000

# Graceful shutdown grace period before forced exit.
# SHUTDOWN_TIMEOUT_MS=10000

# Run `prisma migrate deploy` on container start (single-instance deploys only).
# Prefer a dedicated migration step in your pipeline for multi-instance.
# RUN_DB_MIGRATIONS=true

# Stripe (server-only — credit pack checkout + subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription price ids. Defaults to the LIVE single-user prices (monthly
# £24.99 / yearly £239.90, product prod_UlqgAP1QhnbSDG). Override with TEST-mode
# price ids whenever STRIPE_SECRET_KEY is a sk_test_ key.
# STRIPE_PRICE_SUB_MONTHLY=price_1TmIz4GUamToC80XxfxbK97Y
# STRIPE_PRICE_SUB_YEARLY=price_1TmIz8GUamToC80XY8xDcAWd
# Stripe Checkout success/cancel URLs are derived from the request origin by
# default. For a fixed canonical domain, ensure the browser calls the API from
# https://app.psychiatry.ink so sessions return to:
#   success: https://app.psychiatry.ink/dashboard/credits?checkout=success
#   cancel:  https://app.psychiatry.ink/dashboard/credits?checkout=cancelled
# Configure the webhook endpoint in Stripe → Developers → Webhooks:
#   https://app.psychiatry.ink/api/stripe/webhook  (event: checkout.session.completed)

# Credits are ADDITIVE to a plan: bought packs and bought/redeemed gift vouchers
# bank credits, but USING (spending) them requires an active subscription or an
# active trial. Defaults to ON (enforced). Set to "false" to roll the enforcement
# back without a redeploy (restores the legacy "purchased_credits > 0 unlocks
# access" behaviour). Buying/redeeming credits is ALWAYS allowed regardless.
# REQUIRE_SUBSCRIPTION_FOR_CREDITS=true

# ── Admin allowlists (privileged operators — match verified Supabase user ids)
# Manual AI credit grants (/api/ai-credits/grant). REQUIRED in production for the
# grant route to work at all; empty = nobody can grant.
# CREDIT_ADMIN_USER_IDS=
# Dev-only convenience: with no CREDIT_ADMIN_USER_IDS, allow grants when true.
# ALLOW_DEV_CREDIT_GRANT=true

# Local dev without Supabase login — development ONLY (NODE_ENV=development)
# ENABLE_DEV_AUTH_BYPASS=true

# LLM providers (server-only — never use VITE_ prefix)
# Required for real (non-mock) Labor KI / document generation. At least one key must be set.
#
# PER-TIER MODEL STRATEGY (distinct model per user-selectable tier):
#   Economical (fast)   → DeepSeek deepseek-v4-flash  (non-EU primary; cheapest)
#                         EU fallback → Mistral small (mistral-small-latest)
#   Standard (standard) → Google Gemini (GOOGLE_STANDARD_MODEL, US/SCC-DPF, EU-ok)
#   Gründlich (thorough)→ OpenAI gpt-5.5 reasoning model (most capable)
# Credit multipliers scale with the tier: economic 1× / standard 2× / gründlich 4×.
# Each tier auto-falls back to another configured provider if its key is missing.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# KB seed + write API (server-only — service role bypasses RLS for AI drafts).
# Any authenticated user may edit KB content and report issues; this key backs
# those service-role writes that the secure RLS blocks for the anon client.
SUPABASE_SERVICE_ROLE_KEY=

# Platform Knowledge Base admin allowlist (verified Supabase user ids / emails,
# comma-sep). The SOLE elevated role over the global KB — gates destructive/global
# operations (publish / approve / archive / contribution review). Governs only the
# global KB admin role, NOT general system administration. Server-only and never
# client-trusted. REQUIRED in production: an empty list denies all KB admin
# operations in prod; in non-prod an empty list is permissive for local dev.
# SYSTEM_ADMIN_USER_IDS is a deprecated alias still read as a fallback.
# KB_ADMIN_USER_IDS=

# Optional UX hint for the browser: which ids/emails see the KB review console
# (comma-sep). Convenience only — access is always enforced server-side by
# KB_ADMIN_USER_IDS, never by this client value.
# VITE_SYSTEM_ADMIN_USER_IDS is a deprecated alias still read as a fallback.
# VITE_KB_ADMIN_USER_IDS=

# WHO ICD-API (server-only — official diagnosis titles for UI display)
# Register at https://icd.who.int/icdapi → View API access key
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
# Optional release pins (defaults: ICD-11 2026-01, ICD-10 2016)
# WHO_ICD11_RELEASE=2026-01
# WHO_ICD10_RELEASE=2016

# ── Übersicht psychopathology AI (PPB Strukturieren) ─────────────────────────
# Separate from document-import AI (ENABLE_DOCUMENT_IMPORT_AI). OFF by default.
# Client + server must both be true; restart `npm run dev` after changing .env.local.
# VITE_ENABLE_PSYCHOPATH_EXTRACT_AI=true
# ENABLE_PSYCHOPATH_EXTRACT_AI=true

# Optional model overrides (server-side)
# NOTE: OPENAI_FAST_MODEL / OPENAI_STANDARD_MODEL are no longer used — the live
# tiers are DeepSeek (fast) / Gemini (standard) / OpenAI gpt-5.5 (thorough), with
# Mistral as the EU fallback. They are kept here only as documentation of history.
# OPENAI_FAST_MODEL=gpt-4o-mini
# OPENAI_STANDARD_MODEL=gpt-4o-mini
# Gründlich (thorough) tier model. Default gpt-5.5 (GPT-5-series reasoning model;
# the call path sends max_completion_tokens and omits a custom temperature for it).
OPENAI_THOROUGH_MODEL=gpt-5.5
# Standard tier model — Google Gemini via the OpenAI-compatible endpoint.
GOOGLE_STANDARD_MODEL=gemini-3.5-flash
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# Mistral AI (EU residency) model overrides. small = EU fallback for the
# Economical/Standard tiers; large = EU fallback for the Gründlich tier.
MISTRAL_SMALL_MODEL=mistral-small-latest
MISTRAL_LARGE_MODEL=mistral-large-latest

# ── LLM data-residency gating (EU clinical data) ─────────────────────────────
# The Economical (fast) tier routes to DeepSeek, which processes requests in
# CHINA (no EU adequacy decision). Even though all payloads are de-identified
# server-side, EU deployments may need to exclude it.
#   LLM_RESIDENCY=eu          → block providers outside the EU-approved set
#                               (currently DeepSeek). The Economical tier then
#                               reroutes to Mistral small (EU); Standard stays on
#                               Gemini and Gründlich on OpenAI gpt-5.5 (both US,
#                               permitted under SCC/DPF). Requires an OpenAI/Google/
#                               Mistral key configured, else AI calls fail closed
#                               (451). Mistral AI is an EU-residency provider.
#   LLM_BLOCKED_PROVIDERS=... → explicit provider blocklist (any environment).
# Leave unset for global (non-EU) deployments.
# LLM_RESIDENCY=eu
# LLM_BLOCKED_PROVIDERS=deepseek

# Google Gemini (OpenAI-compatible API — server-only)
GOOGLE_API_KEY=
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Mistral AI — la Plateforme (OpenAI-compatible API, server-only). French/EU
# provider; counts as an EU-residency option and is a compliant choice/fallback
# under LLM_RESIDENCY=eu. Get a key at https://console.mistral.ai
MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Clinical Intelligence V1 (Dimensional + Mechanism inference) ─────────────
# OFF by default. Module is hidden until BOTH client + server flags are true.
# Only de-identified compact evidence is ever sent — raw documents are rejected.
# Restart `npm run dev` after changing .env.local.
# VITE_CLINICAL_INTELLIGENCE_V1_ENABLED=true
# CLINICAL_INTELLIGENCE_V1_ENABLED=true
# Optional development diagnostics panel (raw JSON, tokens, validation, errors)
# VITE_CLINICAL_INTELLIGENCE_DEBUG_MODE=true
# CLINICAL_INTELLIGENCE_DEBUG_MODE=true
