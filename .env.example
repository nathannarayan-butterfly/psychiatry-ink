# ── Database (PostgreSQL / Supabase, via Prisma) ─────────────────────────────
# PRODUCTION (Supabase): use the POOLED connection for the running API and the
# DIRECT connection for migrations. Find both under Supabase → Project Settings
# → Database → Connection string.
#
#   DATABASE_URL → Transaction pooler (PgBouncer, port 6543). MUST include
#                  ?pgbouncer=true so Prisma disables prepared statements.
#   DIRECT_URL   → Direct connection (port 5432). Used by `prisma migrate deploy`
#                  / `prisma db push` only (migrations can't run over PgBouncer).
#
# Example (replace <project-ref>, <password>, <region>):
#   DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#
# LOCAL DEV fallback: SQLite is no longer supported. Point both at a local
# Postgres (or directly at the Supabase project), e.g.:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/psychiatry_ink"

# ── Supabase Auth (browser — Vite, VITE_ prefix) ─────────────────────────────
# EU DATA RESIDENCY: the live project is hosted in AWS eu-west-1 (Ireland, EU);
# DB/Auth/Storage share that region and it CANNOT be changed in place. See
# docs/cloud-deployment.md §6a before creating/moving a project.
# Vite lädt .env.local MIT VORRANG vor .env — Platzhalter nur hier in .env.example.
# Echte Werte in .env.local (empfohlen) oder .env eintragen; .env.example wird nie gelesen.
#
# Dashboard: Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   Key (eine Variable, zwei Formate):
#     • Legacy anon JWT:  eyJ…              → VITE_SUPABASE_ANON_KEY
#     • Publishable key:  sb_publishable_…  → ebenfalls VITE_SUPABASE_ANON_KEY
#   NICHT im Browser: sb_secret_… oder service_role JWT
#
# Nach Änderungen: npm run dev neu starten.
# Supabase → Auth → URL Configuration:
#   DEV  Site URL http://localhost:5173       Redirect URLs http://localhost:5173/**
#   PROD Site URL https://app.psychiatry.ink  Redirect URLs https://app.psychiatry.ink/**
#        (add every real domain you serve the app from, incl. www if used)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ── Supabase Auth (server — optional, getrennt vom Client) ───────────────────
# Fallback auf VITE_* wenn leer. Gleiche .env.local-Vorrang-Regel wie oben.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# API server
API_PORT=3001
# Bind address. 0.0.0.0 inside containers; 127.0.0.1 for local-only.
# API_HOST=0.0.0.0
# Number of reverse-proxy hops to trust for client IP / rate limiting (default 1).
# TRUST_PROXY=1

# ── Deployment topology ──────────────────────────────────────────────────────
# Default = SINGLE SERVICE: the API serves the built dist/ with SPA fallback, so
# the browser talks to same-origin /api/* and VITE_API_BASE_URL can stay unset.
#
# SPLIT DEPLOY: host the frontend separately and set VITE_API_BASE_URL (at BUILD
# time for the client) to the API origin. Then you MUST also set
# CORS_ALLOWED_ORIGINS below to the frontend origin(s).
# Dev leaves this unset and uses the Vite proxy to API_PORT.
# VITE_API_BASE_URL=https://api.psychiatry.ink

# ── CORS allowlist ───────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to call the API cross-origin.
# localhost is always allowed in non-production. Required for split deploys;
# safe to leave empty for the same-origin single-service topology.
# CORS_ALLOWED_ORIGINS=https://app.psychiatry.ink,https://www.psychiatry.ink
# Extra origins to add to the CSP connect-src (rarely needed).
# CSP_CONNECT_SRC_EXTRA=

# ── Rate limiting (per-instance, in-memory) ──────────────────────────────────
# NOTE: counters are per-instance. Add a shared store (rate-limit-redis) before
# scaling beyond one API instance.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_SENSITIVE_MAX=30

# ── Outbound call timeouts (ms) ──────────────────────────────────────────────
# OUTBOUND_HTTP_TIMEOUT_MS=45000
# LLM_TIMEOUT_MS=60000
# TRANSCRIBE_TIMEOUT_MS=60000
# WHO_ICD_TIMEOUT_MS=30000
# SUPABASE_ADMIN_TIMEOUT_MS=30000
# AUTH_VALIDATION_TIMEOUT_MS=10000
# STRIPE_TIMEOUT_MS=30000
# STRIPE_MAX_NETWORK_RETRIES=1

# ── Bearer-token validation cache (token validation latency optimization) ────
# AUTH_CACHE_TTL_MS=60000
# AUTH_NEG_CACHE_TTL_MS=10000

# Graceful shutdown grace period before forced exit.
# SHUTDOWN_TIMEOUT_MS=10000

# Run `prisma migrate deploy` on container start (single-instance deploys only).
# Prefer a dedicated migration step in your pipeline for multi-instance.
# RUN_DB_MIGRATIONS=true

# Stripe (server-only — credit pack checkout)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Checkout success/cancel URLs are derived from the request origin by
# default. For a fixed canonical domain, ensure the browser calls the API from
# https://app.psychiatry.ink so sessions return to:
#   success: https://app.psychiatry.ink/dashboard/credits?checkout=success
#   cancel:  https://app.psychiatry.ink/dashboard/credits?checkout=cancelled
# Configure the webhook endpoint in Stripe → Developers → Webhooks:
#   https://app.psychiatry.ink/api/stripe/webhook  (event: checkout.session.completed)

# ── Admin allowlists (privileged operators — match verified Supabase user ids)
# Manual AI credit grants (/api/ai-credits/grant). REQUIRED in production for the
# grant route to work at all; empty = nobody can grant.
# CREDIT_ADMIN_USER_IDS=
# Dev-only convenience: with no CREDIT_ADMIN_USER_IDS, allow grants when true.
# ALLOW_DEV_CREDIT_GRANT=true

# Local dev without Supabase login — development ONLY (NODE_ENV=development)
# ENABLE_DEV_AUTH_BYPASS=true

# LLM providers (server-only — never use VITE_ prefix)
# Required for real (non-mock) Labor KI / document generation. At least one key must be set.
# schnell + standard → DeepSeek; gründlich + dictation → OpenAI (auto-fallback if only one key is set)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# KB seed + write API (server-only — service role bypasses RLS for AI drafts).
# Any authenticated user may edit KB content and report issues; this key backs
# those service-role writes that the secure RLS blocks for the anon client.
SUPABASE_SERVICE_ROLE_KEY=

# Platform System Admin allowlist (verified Supabase user ids / emails, comma-sep).
# The SOLE elevated role over the global KB — gates destructive/global operations
# (publish / approve / archive / contribution review). Server-only and never
# client-trusted. REQUIRED in production: an empty list denies all System Admin
# operations in prod; in non-prod an empty list is permissive for local dev.
# SYSTEM_ADMIN_USER_IDS=

# Optional UX hint for the browser: which ids/emails see the KB review console
# (comma-sep). Convenience only — access is always enforced server-side by
# SYSTEM_ADMIN_USER_IDS, never by this client value.
# VITE_SYSTEM_ADMIN_USER_IDS=

# WHO ICD-API (server-only — official diagnosis titles for UI display)
# Register at https://icd.who.int/icdapi → View API access key
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
# Optional release pins (defaults: ICD-11 2026-01, ICD-10 2016)
# WHO_ICD11_RELEASE=2026-01
# WHO_ICD10_RELEASE=2016

# ── Übersicht psychopathology AI (PPB Strukturieren) ─────────────────────────
# Separate from document-import AI (ENABLE_DOCUMENT_IMPORT_AI). OFF by default.
# Client + server must both be true; restart `npm run dev` after changing .env.local.
# VITE_ENABLE_PSYCHOPATH_EXTRACT_AI=true
# ENABLE_PSYCHOPATH_EXTRACT_AI=true

# Optional model overrides (server-side)
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_STANDARD_MODEL=gpt-4o-mini
OPENAI_THOROUGH_MODEL=gpt-4.1
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# Mistral AI (EU residency) model overrides — small=fast/standard, large=thorough
MISTRAL_SMALL_MODEL=mistral-small-latest
MISTRAL_LARGE_MODEL=mistral-large-latest

# ── LLM data-residency gating (EU clinical data) ─────────────────────────────
# By default fast/standard tiers route to DeepSeek, which processes requests in
# CHINA (no EU adequacy decision). Even though all payloads are de-identified
# server-side, EU deployments may need to exclude it.
#   LLM_RESIDENCY=eu          → block providers outside the EU-approved set
#                               (currently DeepSeek). Requires an OpenAI/Google/
#                               Mistral key configured, else AI calls fail closed
#                               (451). Mistral AI is an EU-residency provider.
#   LLM_BLOCKED_PROVIDERS=... → explicit provider blocklist (any environment).
# Leave unset for global (non-EU) deployments.
# LLM_RESIDENCY=eu
# LLM_BLOCKED_PROVIDERS=deepseek

# Google Gemini (OpenAI-compatible API — server-only)
GOOGLE_API_KEY=
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Mistral AI — la Plateforme (OpenAI-compatible API, server-only). French/EU
# provider; counts as an EU-residency option and is a compliant choice/fallback
# under LLM_RESIDENCY=eu. Get a key at https://console.mistral.ai
MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Clinical Intelligence V1 (Dimensional + Mechanism inference) ─────────────
# OFF by default. Module is hidden until BOTH client + server flags are true.
# Only de-identified compact evidence is ever sent — raw documents are rejected.
# Restart `npm run dev` after changing .env.local.
# VITE_CLINICAL_INTELLIGENCE_V1_ENABLED=true
# CLINICAL_INTELLIGENCE_V1_ENABLED=true
# Optional development diagnostics panel (raw JSON, tokens, validation, errors)
# VITE_CLINICAL_INTELLIGENCE_DEBUG_MODE=true
# CLINICAL_INTELLIGENCE_DEBUG_MODE=true
